# RayLink relay defaults.
#
# Sourced by the relay command after RELAY_* aliases have been mapped onto the
# standard inbound variables (UUID, PRIVATE_KEY, ...). Every value uses
# ${VAR:=default} so environment-provided values win and are preserved.
#
# Paths and service names are deliberately distinct from the terminal node so
# both roles can coexist on one host for testing.

# --- Node basics (relay inbound, client-facing) --------------------------
: "${PORT:=443}"
: "${NODE_NAME:=Relay-Reality}"
: "${NODE_ROLE:=Relay}"
: "${INSTALL_DIR:=/opt/cloud-xray-relay}"
: "${LISTEN_ADDRESS:=0.0.0.0}"
# Public IP family: auto (IPv4 first, fall back to IPv6), or force 4 / 6.
: "${PUBLIC_IP_VERSION:=auto}"

# --- Xray paths and service identity -------------------------------------
: "${XRAY_BIN:=/usr/local/bin/xray}"
: "${XRAY_CONFIG_DIR:=/usr/local/etc/raylink/relay-xray}"
: "${XRAY_CONFIG:=${XRAY_CONFIG_DIR}/config.json}"
: "${XRAY_SHARE_DIR:=/usr/local/share/xray}"
: "${XRAY_SERVICE:=raylink-relay.service}"
: "${XRAY_SERVICE_DESC:=RayLink relay VLESS Reality service}"
: "${XRAY_SERVICE_USER:=xray}"
: "${XRAY_SERVICE_GROUP:=xray}"

# --- Generated files (derived from INSTALL_DIR) --------------------------
: "${CLASH_FILE:=${INSTALL_DIR}/clash.yaml}"
: "${INFO_FILE:=${INSTALL_DIR}/server-info.txt}"
: "${VLESS_FILE:=${INSTALL_DIR}/vless-uri.txt}"
: "${VLESS_URI_LIST_FILE:=${INSTALL_DIR}/vless-uri-list}"
: "${REALITY_ENV_FILE:=${INSTALL_DIR}/reality.env}"

# --- Upstream terminal parameters (relay -> terminal) --------------------
: "${UPSTREAM_ENV_FILE:=${INSTALL_DIR}/upstream.env}"
: "${UPSTREAM_ADDRESS:=}"
: "${UPSTREAM_PORT:=}"
: "${UPSTREAM_UUID:=}"
: "${UPSTREAM_FLOW:=}"
: "${UPSTREAM_SERVER_NAME:=}"
: "${UPSTREAM_FINGERPRINT:=}"
: "${UPSTREAM_PUBLIC_KEY:=}"
: "${UPSTREAM_SHORT_ID:=}"
: "${UPSTREAM_SUBSCRIPTION_URL:=}"
: "${UPSTREAM_VLESS_URI:=}"

# --- Relay inbound Reality endpoint (camouflage target) ------------------
: "${REALITY_DEST:=}"
: "${REALITY_SERVER_NAME:=}"
: "${CLIENT_FINGERPRINT:=}"
: "${CLIENT_FINGERPRINT_POOL:=chrome}"
: "${FLOW:=}"

# --- Relay inbound credentials (blank => generated; reused from reality.env)
: "${RESET_REALITY_CREDENTIALS:=false}"
: "${UUID:=}"
: "${PRIVATE_KEY:=}"
: "${PUBLIC_KEY:=}"
: "${SHORT_ID:=}"

# --- TCP Fast Open (on by default) ---------------------------------------
: "${ENABLE_TFO:=true}"

# --- DNS profile ---------------------------------------------------------
: "${DNS_PROFILE:=mixed}"
: "${SERVER_COUNTRY:=}"

# --- Relay inbound target check ------------------------------------------
: "${CHECK_REALITY_TARGET:=true}"
: "${REALITY_CHECK_STRICT:=false}"
: "${REALITY_CHECK_LOG:=/tmp/relay_reality_target_check.log}"

# --- End-to-end self-test (Client -> Relay -> Terminal -> Internet) ------
: "${REALITY_SELF_TEST:=true}"
: "${REALITY_SELF_TEST_URL:=http://example.com}"
: "${REALITY_SELF_TEST_TIMEOUT:=10}"
: "${REALITY_SELF_TEST_SOCKS_PORT:=10818}"
: "${REALITY_AUTO_FALLBACK:=true}"

# --- HTTP subscription hosting (relay client subscription) ---------------
: "${ENABLE_SUBSCRIPTION:=true}"
: "${SUB_PORT:=8080}"
: "${SUB_TOKEN:=}"
: "${RESET_SUB_TOKEN:=false}"
: "${SUB_RATE_LIMIT:=30r/m}"
: "${SUB_RATE_BURST:=10}"
: "${SUB_ROOT:=${INSTALL_DIR}/public}"
: "${SUB_ENV_FILE:=${INSTALL_DIR}/subscription.env}"
: "${SUB_LIMIT_ZONE:=cloud_xray_relay_sub_limit}"
: "${NGINX_SITE:=/etc/nginx/sites-available/cloud-xray-relay-subscription}"
: "${NGINX_SITE_LINK:=/etc/nginx/sites-enabled/cloud-xray-relay-subscription}"

# --- Periodic health check timer -----------------------------------------
: "${ENABLE_HEALTHCHECK_TIMER:=true}"
: "${RAYLINK_CLI:=/usr/local/bin/raylink}"
: "${HEALTHCHECK_ENV_FILE:=/etc/raylink-relay-healthcheck.env}"
: "${HEALTHCHECK_ON_BOOT_SEC:=10min}"
: "${HEALTHCHECK_ON_UNIT_ACTIVE_SEC:=24h}"
: "${HEALTHCHECK_SERVICE_NAME:=raylink-relay-healthcheck.service}"
: "${HEALTHCHECK_TIMER_NAME:=raylink-relay-healthcheck.timer}"

# --- Local metrics debug endpoint (default off; localhost only) ----------
: "${ENABLE_XRAY_METRICS:=false}"
: "${METRICS_LISTEN:=127.0.0.1:11111}"

# --- Reserved: Xray-side DNS query strategy (UseSystem/UseIPv4/UseIPv6) ---
# Most relevant for IPv6-only relays resolving an upstream by hostname.
: "${XRAY_DNS_QUERY_STRATEGY:=UseSystem}"

# --- Runtime-only state (computed during the run) ------------------------
DNS_DETECTED_COUNTRY=""
DNS_EFFECTIVE_PROFILE=""
PUBLIC_IP_FAMILY=""
PUBLIC_URI_HOST=""
PUBLIC_URL_HOST=""
METRICS_BLOCK=""
NGINX_LISTEN_DIRECTIVE=""
UPSTREAM_CHANGED="false"
