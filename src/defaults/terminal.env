# RayLink terminal defaults.
#
# Sourced by the terminal command. Every value uses ${VAR:=default} so that
# anything already exported in the environment (e.g. `sudo env PORT=8443 ...`)
# takes priority and is preserved.

# --- Node basics ---------------------------------------------------------
: "${PORT:=443}"
: "${NODE_NAME:=Terminal-Reality}"
: "${INSTALL_DIR:=/opt/cloud-xray-terminal}"
: "${LISTEN_ADDRESS:=0.0.0.0}"

# --- Xray paths and service identity -------------------------------------
: "${XRAY_BIN:=/usr/local/bin/xray}"
: "${XRAY_CONFIG_DIR:=/usr/local/etc/xray}"
: "${XRAY_CONFIG:=${XRAY_CONFIG_DIR}/config.json}"
: "${XRAY_SHARE_DIR:=/usr/local/share/xray}"
: "${XRAY_SERVICE:=xray.service}"
: "${XRAY_SERVICE_USER:=xray}"
: "${XRAY_SERVICE_GROUP:=xray}"

# --- Generated files (derived from INSTALL_DIR) --------------------------
: "${CLASH_FILE:=${INSTALL_DIR}/clash.yaml}"
: "${INFO_FILE:=${INSTALL_DIR}/server-info.txt}"
: "${VLESS_FILE:=${INSTALL_DIR}/vless-uri.txt}"
: "${VLESS_URI_LIST_FILE:=${INSTALL_DIR}/vless-uri-list}"
: "${REALITY_ENV_FILE:=${INSTALL_DIR}/reality.env}"

# --- Reality endpoint ----------------------------------------------------
: "${REALITY_DEST:=}"
: "${REALITY_SERVER_NAME:=}"
: "${CLIENT_FINGERPRINT:=}"
: "${CLIENT_FINGERPRINT_POOL:=chrome}"
: "${FLOW:=}"

# --- Reality credentials (blank => generated; reused from reality.env) ---
: "${RESET_REALITY_CREDENTIALS:=false}"
: "${UUID:=}"
: "${PRIVATE_KEY:=}"
: "${PUBLIC_KEY:=}"
: "${SHORT_ID:=}"

# --- TCP Fast Open -------------------------------------------------------
: "${ENABLE_TFO:=false}"

# --- DNS profile ---------------------------------------------------------
: "${DNS_PROFILE:=mixed}"
: "${SERVER_COUNTRY:=}"

# --- Reality target check ------------------------------------------------
: "${CHECK_REALITY_TARGET:=true}"
: "${REALITY_CHECK_STRICT:=false}"
: "${REALITY_CHECK_LOG:=/tmp/reality_target_check.log}"

# --- Reality self-test ---------------------------------------------------
: "${REALITY_SELF_TEST:=true}"
: "${REALITY_SELF_TEST_URL:=http://example.com}"
: "${REALITY_SELF_TEST_TIMEOUT:=10}"
: "${REALITY_SELF_TEST_SOCKS_PORT:=10808}"
: "${REALITY_AUTO_FALLBACK:=true}"

# --- HTTP subscription hosting -------------------------------------------
: "${ENABLE_SUBSCRIPTION:=true}"
: "${SUB_PORT:=8080}"
: "${SUB_TOKEN:=}"
: "${RESET_SUB_TOKEN:=false}"
: "${SUB_RATE_LIMIT:=30r/m}"
: "${SUB_RATE_BURST:=10}"
: "${SUB_ROOT:=${INSTALL_DIR}/public}"
: "${SUB_ENV_FILE:=${INSTALL_DIR}/subscription.env}"
: "${NGINX_SITE:=/etc/nginx/sites-available/cloud-xray-terminal-subscription}"
: "${NGINX_SITE_LINK:=/etc/nginx/sites-enabled/cloud-xray-terminal-subscription}"

# --- Periodic health check timer -----------------------------------------
: "${ENABLE_HEALTHCHECK_TIMER:=true}"
: "${RAYLINK_CLI:=/usr/local/bin/raylink}"
: "${HEALTHCHECK_ENV_FILE:=/etc/raylink-terminal-healthcheck.env}"
: "${HEALTHCHECK_ON_BOOT_SEC:=10min}"
: "${HEALTHCHECK_ON_UNIT_ACTIVE_SEC:=24h}"
: "${HEALTHCHECK_SERVICE_NAME:=raylink-terminal-healthcheck.service}"
: "${HEALTHCHECK_TIMER_NAME:=raylink-terminal-healthcheck.timer}"

# --- Runtime-only state (computed during the run) ------------------------
DNS_DETECTED_COUNTRY=""
DNS_EFFECTIVE_PROFILE=""
