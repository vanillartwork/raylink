# RayLink legacy / compatibility defaults.
#
# Kept separate so that backward-compatibility shims and rarely-changed lists
# do not clutter the main defaults file. Sourced after exit.env.

# Legacy DNS auto-mode: AUTO_DNS_RETURN_COUNTRIES was the previous name for
# the domestic-country list used by DNS_PROFILE=auto.
: "${AUTO_DNS_DOMESTIC_COUNTRIES:=${AUTO_DNS_RETURN_COUNTRIES:-CN}}"

# Reality fallback target candidates, format: dest|serverName|clientFingerprint
# separated by spaces. Kept here (not persisted) so updates take effect on
# re-run instead of freezing an old list.
: "${REALITY_TARGET_CANDIDATES:=www.cloudflare.com:443|www.cloudflare.com|chrome www.apple.com:443|www.apple.com|safari addons.mozilla.org:443|addons.mozilla.org|firefox www.speedtest.net:443|www.speedtest.net|chrome www.microsoft.com:443|www.microsoft.com|chrome}"
