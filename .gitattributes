```gitattributes
# Automatically detect text files and normalize them in the repository.
* text=auto

# Linux and project configuration files must use LF.
*.sh      text eol=lf
*.bash    text eol=lf
*.service text eol=lf
*.conf    text eol=lf
*.env     text eol=lf
*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.md      text eol=lf
*.txt     text eol=lf

# Windows-specific scripts use CRLF.
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary files must not be modified by line-ending normalization.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.tar     binary
```
